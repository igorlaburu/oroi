# Credenciales de los proveedores. Copia este fichero a .env y rellena los valores.
# Hoy la extracción y los embeddings requieren Azure OpenAI; el Conversador puede ser
# Claude o Azure. Cualquier proveedor propio puede inyectarse implementando los
# Protocols de oroi/providers/base.py (Embedder, Extractor, Chat).

# Azure OpenAI — extractor (gpt-4o-mini) y embeddings (text-embedding-3-small)
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=2024-10-21
AZURE_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_KEY=
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Alternativa OpenAI-compatible (OpenAI directo, Ollama, vLLM...) para la memoria:
# MEMORY_PROVIDER=openai la activa. Con Ollama: OPENAI_BASE_URL=http://localhost:11434/v1
# (los embeddings requieren un modelo de embeddings servido en el endpoint, y su dimensión).
MEMORY_PROVIDER=azure
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_CHAT_MODEL=gpt-4o

# El Conversador — "claude", "azure" u "openai"
CHAT_PROVIDER=claude
AZURE_SMART_DEPLOYMENT=gpt-5.4

# Solo con CHAT_PROVIDER=claude — "session" usa la sesión local de Claude Code (cuenta Max,
# sin clave); "api" llama directamente al API y entonces sí requiere ANTHROPIC_API_KEY.
CLAUDE_AUTH=session
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
